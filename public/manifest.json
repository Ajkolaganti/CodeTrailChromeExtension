{
  "manifest_version": 3,
  "name": "CodeTrail",
  "version": "0.1.0",
  "description": "Solve it. Sync it. Show it. Sync accepted LeetCode submissions to GitHub.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": ["storage", "identity", "notifications"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://*.leetcode.com/*",
    "https://api.github.com/*",
    "http://localhost:8787/*"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "CodeTrail",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    },
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://*.leetcode.com/problems/*",
        "https://leetcode.com/problems/*/submissions/*",
        "https://*.leetcode.com/problems/*/submissions/*",
        "https://leetcode.com/submissions/*",
        "https://*.leetcode.com/submissions/*"
      ],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
